---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comments from '../../components/Comments.astro';
import { categoryPath, tagPath, ogImageForPost, getAllPosts, getRelatedPosts, getPrevNext } from '../../utils/blog';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
  return Object.entries(modules).map(([path, post]: [string, any]) => {
    const slug = path.split('/').pop()?.replace('.md', '') || '';
    return {
      params: { slug },
      props: { post, slug },
    };
  });
}

const { post, slug } = Astro.props;
const { Content } = post;
const { title, description, date, updated, category, tags = [], image } = post.frontmatter;
const commentsEnabled = Boolean(import.meta.env.PUBLIC_COMMENTS_API_URL);

const site = Astro.site ?? new URL('https://perust.github.io');
const pageUrl = new URL(Astro.url.pathname, site).toString();
const publishedISO = new Date(date).toISOString();
const modifiedISO = updated ? new Date(updated).toISOString() : publishedISO;

// 글 OG 이미지: frontmatter image > public/og/posts/<slug>.png(있을 때) > 카테고리 기본.
// 빌드 시 글별 이미지가 실제로 있는지 확인해, 아직 생성 안 된 새 글에서도 깨지지 않게 한다.
// (astro build의 cwd는 프로젝트 루트다.)
const postImageExists = existsSync(join(process.cwd(), 'public', 'og', 'posts', `${slug}.png`));
const ogImage = ogImageForPost({ image, category, slug }, postImageExists);
const ogImageUrl = new URL(ogImage, site).toString();
const categoryUrl = new URL(categoryPath(category), site).toString();

// 본문 아래에 보여줄 관련 글과 이전/다음 글. 최신순 목록을 공유 헬퍼로 가져온다.
const allPosts = getAllPosts();
const currentPost = allPosts.find((post) => post.slug === slug);
const relatedPosts = currentPost ? getRelatedPosts(currentPost, allPosts) : [];
const { prev, next } = getPrevNext(slug, allPosts);
const formatDate = (value: string | Date) => new Date(value).toLocaleDateString('ko-KR');

const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  inLanguage: 'ko-KR',
  datePublished: publishedISO,
  dateModified: modifiedISO,
  url: pageUrl,
  image: ogImageUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  author: { '@type': 'Person', name: 'slowave', url: site.toString() },
  publisher: {
    '@type': 'Organization',
    name: 'slowave',
    url: site.toString(),
    logo: {
      '@type': 'ImageObject',
      url: new URL('/icon-512.png', site).toString(),
      width: 512,
      height: 512,
    },
  },
  articleSection: category,
  ...(tags.length ? { keywords: tags.join(', ') } : {}),
};

// Home > Blog > category > post 순서의 BreadcrumbList.
// 카테고리는 전용 정적 페이지(/blog/category/<slug>/)를 가리킨다.
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: '블로그', item: new URL('/blog/', site).toString() },
    { '@type': 'ListItem', position: 3, name: category, item: categoryUrl },
    { '@type': 'ListItem', position: 4, name: title, item: pageUrl },
  ],
};
---
<BaseLayout title={`${title} · slowave 블로그`} description={description} canonical={Astro.url.pathname} ogType="article" jsonLd={[blogPostingLd, breadcrumbLd]} publishedTime={publishedISO} modifiedTime={modifiedISO} tags={tags} image={ogImage}>
  <main class="post-layout">
    <article class="post-article">
      <p class="section-kicker"><a href={categoryPath(category)}>{category}</a></p>
      <h1>{title}</h1>
      <p class="post-meta">
        <time datetime={publishedISO}>{new Date(date).toLocaleDateString('ko-KR')}</time>
        {updated && <span> · 수정 <time datetime={modifiedISO}>{new Date(updated).toLocaleDateString('ko-KR')}</time></span>}
      </p>
      <Content />

      {relatedPosts.length > 0 && (
        <section class="post-related" aria-label="관련 글">
          <h2 class="post-related-title">관련 글</h2>
          <ul class="related-grid">
            {relatedPosts.map((related) => (
              <li>
                <a class="related-card" href={`/blog/${related.slug}/`} aria-label={`관련 글: ${related.title}`}>
                  <span class="related-category">{related.category}</span>
                  <time datetime={new Date(related.date).toISOString()}>{formatDate(related.date)}</time>
                  <h3>{related.title}</h3>
                  <p>{related.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {(prev || next) && (
        <nav class="post-pager" aria-label="이전 다음 글 이동">
          {prev ? (
            <a class="post-pager-link is-prev" href={`/blog/${prev.slug}/`} rel="prev" aria-label={`이전 글: ${prev.title}`}>
              <span class="post-pager-dir">← 이전 글</span>
              <span class="post-pager-title">{prev.title}</span>
            </a>
          ) : <span class="post-pager-spacer" aria-hidden="true"></span>}
          {next ? (
            <a class="post-pager-link is-next" href={`/blog/${next.slug}/`} rel="next" aria-label={`다음 글: ${next.title}`}>
              <span class="post-pager-dir">다음 글 →</span>
              <span class="post-pager-title">{next.title}</span>
            </a>
          ) : <span class="post-pager-spacer" aria-hidden="true"></span>}
        </nav>
      )}

      {commentsEnabled && <Comments slug={slug} />}
    </article>
    <aside class="sidebar-card" aria-label="블로그 안내">
      <h2 style="font-size:1.2rem">slowave Blog</h2>
      <p>아이디어를 제품으로 만들며 배운 것을 기록합니다.</p>
      <ul class="tag-cloud">{tags.map((tag: string) => <li><a href={tagPath(tag)}>#{tag}</a></li>)}</ul>
    </aside>
  </main>
</BaseLayout>
