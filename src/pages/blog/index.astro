---
import BaseLayout from '../../layouts/BaseLayout.astro';

const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.entries(modules)
  .map(([path, post]: [string, any]) => ({
    slug: path.split('/').pop()?.replace('.md', ''),
    ...post.frontmatter,
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const featuredPost = posts[0];
const restPosts = posts.slice(1);
const categories = Array.from(new Set(posts.map((post) => post.category))).sort();

const site = Astro.site ?? new URL('https://perust.github.io');
const blogDescription = '프로젝트 제작기, AI 자동화, 투자 데이터, 회고 시스템을 다루는 개인 블로그.';
const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'slowave 블로그',
  description: blogDescription,
  url: new URL('/blog/', site).toString(),
  inLanguage: 'ko-KR',
  publisher: { '@type': 'Organization', name: 'slowave', url: site.toString() },
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.description,
    datePublished: new Date(post.date).toISOString(),
    url: new URL(`/blog/${post.slug}/`, site).toString(),
  })),
};
---
<BaseLayout title="Blog · slowave" description={blogDescription} jsonLd={blogLd}>
  <main>
    <section class="section-shell blog-hero blog-hero-compact">
      <p class="section-kicker">Blog</p>
      <h1>블로그</h1>
      <p class="hero-description">프로젝트 제작기, AI 자동화, 투자 데이터, 회고 시스템을 글로 정리합니다. 네이버 블로그에 올린 책 리뷰와 공부 기록도 함께 모아둡니다.</p>
    </section>

    <section class="section-shell blog-page" aria-label="블로그 글 목록">
      <div class="blog-main-list">
        {featuredPost && (
          <a class="featured-post-card blog-post-entry" data-category={featuredPost.category} href={`/blog/${featuredPost.slug}/`}>
            <div>
              <span class="category-chip">{featuredPost.category}</span>
              <time datetime={new Date(featuredPost.date).toISOString()}>{new Date(featuredPost.date).toLocaleDateString('ko-KR')}</time>
            </div>
            <h2>{featuredPost.title}</h2>
            <p>{featuredPost.description}</p>
            <ul class="post-tags">{featuredPost.tags?.map((tag: string) => <li>{tag}</li>)}</ul>
          </a>
        )}

        <div class="post-list">
          {restPosts.map((post) => (
            <a class="post-list-item blog-post-entry" data-category={post.category} href={`/blog/${post.slug}/`}>
              <div class="post-list-meta">
                <span>{post.category}</span>
                <time datetime={new Date(post.date).toISOString()}>{new Date(post.date).toLocaleDateString('ko-KR')}</time>
              </div>
              <div>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
                <ul class="post-tags">{post.tags?.map((tag: string) => <li>{tag}</li>)}</ul>
              </div>
            </a>
          ))}
        </div>
        <p class="empty-blog-message" hidden>선택한 카테고리에 글이 없습니다.</p>
      </div>

      <aside class="blog-sidebar" aria-label="블로그 분류">
        <div class="sidebar-card">
          <h2>카테고리</h2>
          <ul class="category-list">
            <li><a class="category-filter is-active" href="/blog/" data-category="all"><span>전체</span><strong>{posts.length}</strong></a></li>
            {categories.map((category) => <li><a class="category-filter" href={`/blog/?category=${encodeURIComponent(category)}`} data-category={category}><span>{category}</span><strong>{posts.filter((post) => post.category === category).length}</strong></a></li>)}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2>최근 글</h2>
          <ol class="recent-post-list">
            {posts.slice(0, 5).map((post) => <li><a href={`/blog/${post.slug}/`}>{post.title}</a></li>)}
          </ol>
        </div>
      </aside>
    </section>
  </main>
  <script>
    const entries = Array.from(document.querySelectorAll('.blog-post-entry'));
    const filters = Array.from(document.querySelectorAll('.category-filter'));
    const emptyMessage = document.querySelector('.empty-blog-message');

    function applyCategory(category, pushState = true) {
      let visibleCount = 0;
      entries.forEach((entry) => {
        const shouldShow = category === 'all' || entry.dataset.category === category;
        entry.hidden = !shouldShow;
        if (shouldShow) visibleCount += 1;
      });
      filters.forEach((filter) => {
        filter.classList.toggle('is-active', filter.dataset.category === category);
      });
      if (emptyMessage) emptyMessage.hidden = visibleCount !== 0;
      if (pushState) {
        const url = category === 'all' ? '/blog/' : `/blog/?category=${encodeURIComponent(category)}`;
        history.pushState({ category }, '', url);
      }
    }

    filters.forEach((filter) => {
      filter.addEventListener('click', (event) => {
        event.preventDefault();
        applyCategory(filter.dataset.category || 'all');
      });
    });

    const initialCategory = new URLSearchParams(window.location.search).get('category') || 'all';
    applyCategory(initialCategory, false);

    window.addEventListener('popstate', () => {
      const category = new URLSearchParams(window.location.search).get('category') || 'all';
      applyCategory(category, false);
    });
  </script>
</BaseLayout>
