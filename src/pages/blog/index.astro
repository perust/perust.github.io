---
import BaseLayout from '../../layouts/BaseLayout.astro';

const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.entries(modules)
  .map(([path, post]: [string, any]) => ({
    slug: path.split('/').pop()?.replace('.md', ''),
    ...post.frontmatter,
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
---
<BaseLayout title="Blog · 임승우" description="프로젝트 제작기, AI 자동화, 투자 데이터, 회고 시스템을 다루는 임승우의 블로그.">
  <main>
    <section class="section-shell blog-hero">
      <p class="section-kicker">Blog</p>
      <h1>만드는 과정까지 자산으로 남깁니다.</h1>
      <p class="hero-description">프로젝트 제작기, AI 자동화, 투자 데이터, 회고 시스템을 검색 가능한 글로 정리합니다. 수익화보다 먼저 신뢰할 수 있는 글과 독자에게 도움이 되는 경험을 쌓는 공간입니다.</p>
    </section>
    <section class="section-shell" aria-label="블로그 글 목록">
      <div class="blog-grid">
        {posts.map((post) => <a class="post-card" href={`/blog/${post.slug}/`}><span class="category-chip">{post.category}</span><time datetime={new Date(post.date).toISOString()}>{new Date(post.date).toLocaleDateString('ko-KR')}</time><h2>{post.title}</h2><p>{post.description}</p><ul class="post-tags">{post.tags?.map((tag: string) => <li>{tag}</li>)}</ul></a>)}
      </div>
    </section>
  </main>
</BaseLayout>
