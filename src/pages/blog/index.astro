---
import BaseLayout from '../../layouts/BaseLayout.astro';

const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.entries(modules)
  .map(([path, post]: [string, any]) => ({
    slug: path.split('/').pop()?.replace('.md', ''),
    ...post.frontmatter,
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const featuredPost = posts[0];
const restPosts = posts.slice(1);
const categories = Array.from(new Set(posts.map((post) => post.category))).sort();
---
<BaseLayout title="Blog · 임승우" description="프로젝트 제작기, AI 자동화, 투자 데이터, 회고 시스템을 다루는 임승우의 블로그.">
  <main>
    <section class="section-shell blog-hero blog-hero-compact">
      <p class="section-kicker">Blog</p>
      <h1>블로그</h1>
      <p class="hero-description">프로젝트 제작기, AI 자동화, 투자 데이터, 회고 시스템을 글로 정리합니다. 네이버 블로그에 올린 책 리뷰와 공부 기록도 함께 모아둡니다.</p>
    </section>

    <section class="section-shell blog-page" aria-label="블로그 글 목록">
      <div class="blog-main-list">
        {featuredPost && (
          <a class="featured-post-card" href={`/blog/${featuredPost.slug}/`}>
            <div>
              <span class="category-chip">{featuredPost.category}</span>
              <time datetime={new Date(featuredPost.date).toISOString()}>{new Date(featuredPost.date).toLocaleDateString('ko-KR')}</time>
            </div>
            <h2>{featuredPost.title}</h2>
            <p>{featuredPost.description}</p>
            <ul class="post-tags">{featuredPost.tags?.map((tag: string) => <li>{tag}</li>)}</ul>
          </a>
        )}

        <div class="post-list">
          {restPosts.map((post) => (
            <a class="post-list-item" href={`/blog/${post.slug}/`}>
              <div class="post-list-meta">
                <span>{post.category}</span>
                <time datetime={new Date(post.date).toISOString()}>{new Date(post.date).toLocaleDateString('ko-KR')}</time>
              </div>
              <div>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
                <ul class="post-tags">{post.tags?.map((tag: string) => <li>{tag}</li>)}</ul>
              </div>
            </a>
          ))}
        </div>
      </div>

      <aside class="blog-sidebar" aria-label="블로그 분류">
        <div class="sidebar-card">
          <h2>카테고리</h2>
          <ul class="category-list">
            {categories.map((category) => <li><span>{category}</span><strong>{posts.filter((post) => post.category === category).length}</strong></li>)}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2>최근 글</h2>
          <ol class="recent-post-list">
            {posts.slice(0, 5).map((post) => <li><a href={`/blog/${post.slug}/`}>{post.title}</a></li>)}
          </ol>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
