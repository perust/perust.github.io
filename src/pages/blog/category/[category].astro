---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllPosts, slugify, categoryPath, ogImageForCategory } from '../../../utils/blog';

// 글에 등장하는 카테고리마다 정적 페이지를 만든다.
export function getStaticPaths() {
  const posts = getAllPosts();
  const categories = Array.from(new Set(posts.map((post) => post.category)));
  return categories.map((category) => ({
    params: { category: slugify(category) },
    props: { category, posts: posts.filter((post) => post.category === category) },
  }));
}

const { category, posts } = Astro.props;
const site = Astro.site ?? new URL('https://perust.github.io');
const path = categoryPath(category);
const pageUrl = new URL(path, site).toString();

const title = `${category} 글 모음 · slowave 블로그`;
const description = `slowave 블로그의 ${category} 카테고리 글 ${posts.length}편을 모았습니다. 최신 글부터 차례로 정리했습니다.`;

// CollectionPage + ItemList JSON-LD. 답변엔진이 "이 카테고리의 글 목록"을 그대로 읽을 수 있게 한다.
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${category} · slowave 블로그`,
  description,
  url: pageUrl,
  inLanguage: 'ko-KR',
  isPartOf: { '@type': 'Blog', name: 'slowave 블로그', url: new URL('/blog/', site).toString() },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: posts.length,
    itemListElement: posts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: new URL(`/blog/${post.slug}/`, site).toString(),
      name: post.title,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: '블로그', item: new URL('/blog/', site).toString() },
    { '@type': 'ListItem', position: 3, name: category, item: pageUrl },
  ],
};
---
<BaseLayout title={title} description={description} canonical={path} jsonLd={[collectionLd, breadcrumbLd]} image={ogImageForCategory(category)}>
  <main>
    <section class="section-shell blog-hero blog-hero-compact">
      <p class="section-kicker"><a href="/blog/">블로그</a> · 카테고리</p>
      <h1>{category}</h1>
      <p class="hero-description">{category} 카테고리로 묶인 글 {posts.length}편입니다. 최신순으로 정리했습니다.</p>
    </section>

    <section class="section-shell blog-main-list" aria-label={`${category} 글 목록`} style="padding-top:0">
      <div class="post-list">
        {posts.map((post) => (
          <a class="post-list-item" href={`/blog/${post.slug}/`}>
            <div class="post-list-meta">
              <span>{post.category}</span>
              <time datetime={new Date(post.date).toISOString()}>{new Date(post.date).toLocaleDateString('ko-KR')}</time>
            </div>
            <div>
              <h2>{post.title}</h2>
              <p>{post.description}</p>
              <ul class="post-tags">{post.tags?.map((tag: string) => <li>{tag}</li>)}</ul>
            </div>
          </a>
        ))}
      </div>
      <p style="margin-top:1.5rem"><a class="text-link" href="/blog/">← 블로그 전체 글 보기</a></p>
    </section>
  </main>
</BaseLayout>
