---
import BaseLayout from '../layouts/BaseLayout.astro';

const archiveItems = [
  ['Contents', '2022', '끝말잇기 게임', 'JavaScript 게임 로직 · 순수 JS 구현', '/contents/word-relay.html'],
  ['Contents', '2022', '계산기', 'JavaScript 연습 · 사칙연산 구현', '/contents/calculator.html'],
  ['Contents', '2022', '숫자야구 게임', 'JavaScript 연습 · 게임 로직 구현', '/contents/number-baseball.html'],
  ['Homepage', '2022', '플라워가든 페이지', 'HTML/CSS · 이미지 중심 레이아웃', '/homepage/flower/index.html'],
  ['Homepage', '2022', '교보문고 모바일 리디자인', '모바일 UI 실습 · 반응형 리디자인', '/homepage/gyobo/index.html'],
  ['Homepage', '2022', '더페이스샵 모바일 리디자인', '모바일 UI 실습 · 뷰티 브랜드 리디자인', '/homepage/thefaceshop/index.html'],
  ['Homepage', '2022', '뚜레쥬르 PC 리디자인', 'PC UI 실습 · 브랜드 사이트 리디자인', '/homepage/tous/index.html'],
  ['Homepage', '2022', '삼진어묵 메인', '웹 퍼블리싱 · 메인 페이지', '/homepage/3z/index.html'],
  ['Homepage', '2022', '삼진어묵 서브', '웹 퍼블리싱 · 서브 페이지', '/homepage/3z/sub.html'],
  ['Study', '2022', '렛츠기릿 자바스크립트', '자바스크립트 입문 · 강의 실습 모음', '/study/ZeroCho-JavaScript-Beginner/index.html'],
  ['Study', '2022', '반응형 웹 만들기', 'HTML/CSS 스터디 · 반응형 레이아웃', '/study/responsive-web-design2017/index.html'],
];

const site = Astro.site ?? new URL('https://perust.github.io');
const homeDescription = '개인 포트폴리오와 블로그. 아이디어를 제품으로 옮기는 과정, AI 자동화, 투자 데이터, 회고 시스템을 기록합니다.';
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'slowave',
  url: site.toString(),
  inLanguage: 'ko-KR',
  description: homeDescription,
  publisher: { '@type': 'Organization', name: 'slowave', url: site.toString() },
};
---
<BaseLayout title="slowave · 메이커 포트폴리오와 블로그" description={homeDescription} jsonLd={websiteLd}>
  <main id="top">
    <section class="hero section-shell" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">Maker · Product Builder · Blog</p>
        <h1 id="hero-title">아이디어를 더 빨리 검증하고,<br />쓸 수 있는 제품으로 만듭니다.</h1>
        <p class="hero-description">안녕하세요. 떠오른 아이디어를 실제로 써볼 수 있는 것으로 바꾸는 과정을 기록합니다. 이곳은 포트폴리오이자, 프로젝트·AI 자동화·투자 데이터·회고 시스템을 다루는 블로그입니다.</p>
        <div class="hero-actions">
          <a class="button primary" href="/blog/">블로그 읽기</a>
          <a class="button secondary" href="#projects">진행 중인 작업 보기</a>
          <a class="button secondary" href="https://github.com/perust" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <aside class="hero-card" aria-label="프로필 요약">
        <div class="status-pill"><span></span> 현재 만들고 기록하는 중</div>
        <dl class="profile-list">
          <div><dt>닉네임</dt><dd>slowave</dd></div>
          <div><dt>관심사</dt><dd>아이디어 → 제품, 생산성, 투자 데이터, 회고 시스템</dd></div>
          <div><dt>스택</dt><dd>React · Python · Supabase · Astro · AI-assisted build</dd></div>
        </dl>
      </aside>
    </section>

    <section id="focus" class="section-shell split-section" aria-labelledby="focus-title">
      <div><p class="section-kicker">Current focus</p><h2 id="focus-title">요즘의 초점</h2></div>
      <div class="focus-grid">
        <article class="focus-card"><span class="card-index">01</span><h3>생각을 제품으로 바꾸는 속도</h3><p>막연한 아이디어를 빠르게 화면으로 만들어 검증합니다. 완벽한 설계보다 먼저 작동하는 첫 버전이 중요합니다.</p></article>
        <article class="focus-card"><span class="card-index">02</span><h3>AI와 함께 만드는<br />개인 업무 자동화</h3><p>코딩, 문서화, 리서치에 AI를 연결해 반복 업무를 줄이고, 남는 시간은 더 중요한 판단에 씁니다.</p></article>
        <article class="focus-card"><span class="card-index">03</span><h3>쌓아두는 기록 자산</h3><p>개발 과정과 시행착오를 검색 가능한 글로 남겨, 나중에 다시 꺼내볼 수 있는 자료로 만듭니다.</p></article>
      </div>
    </section>

    <section id="projects" class="section-shell" aria-labelledby="projects-title">
      <div class="section-heading"><p class="section-kicker">Projects & work</p><h2 id="projects-title">현재 진행 중인 작업</h2><p>지금 작업 중인 것들을 정리했습니다. 실제로 써보면서 개선하는 것을 중요하게 생각합니다.</p></div>
      <div class="project-grid">
        <article class="project-card featured"><div class="project-meta"><span>Product</span><span>Reflection</span></div><h3>회고/리뷰 노트 제품</h3><p>하루와 선택을 돌아보고 패턴을 발견하는 기록 도구를 만들고 있습니다. 단순 메모가 아니라 다음 행동으로 이어지는 리뷰 경험이 목표입니다.</p><ul class="tag-list" aria-label="사용 기술 및 키워드"><li>React</li><li>Supabase</li><li>UX Writing</li></ul></article>
        <article class="project-card"><div class="project-meta"><span>Data</span><span>Investing</span></div><h3>SOXL Analyzer</h3><p>감정 대신 데이터로 투자를 확인할 수 있도록 분석 화면을 만들고 있습니다. 필요한 지표를 한눈에 볼 수 있게 하는 게 목표입니다.</p><ul class="tag-list" aria-label="사용 기술 및 키워드"><li>Python</li><li>Chart</li><li>Decision support</li></ul></article>
        <article class="project-card"><div class="project-meta"><span>Writing</span><span>Blog</span></div><h3>제작 기록 블로그</h3><p>프로젝트 제작기, AI 자동화, 투자 데이터 실험을 글로 정리합니다. 직접 해본 것과 배운 점을 남기는 공간입니다.</p><a class="text-link" href="/blog/">블로그 보기 →</a></article>
      </div>
    </section>

    <section id="principles" class="section-shell principles" aria-labelledby="principles-title">
      <div class="section-heading compact"><p class="section-kicker">Principles</p><h2 id="principles-title">일하는 기준</h2></div>
      <ol class="principle-list"><li><strong>명확하게 생각하기</strong><span>좋은 결과는 문제를 제대로 이름 붙이는 데서 시작한다고 믿습니다.</span></li><li><strong>작게 만들고 빠르게 배우기</strong><span>큰 계획보다 작동하는 첫 버전과 사용자 피드백을 우선합니다.</span></li><li><strong>효율은 자유를 만든다</strong><span>자동화와 도구화로 시간을 되찾고 더 중요한 선택에 에너지를 씁니다.</span></li><li><strong>기록으로 나를 업데이트하기</strong><span>생각, 감정, 결과를 남겨 다음 결정의 품질을 높입니다.</span></li></ol>
    </section>

    <section id="archive" class="section-shell" aria-labelledby="archive-title">
      <div class="section-heading"><p class="section-kicker">Archive & lab</p><h2 id="archive-title">예전 작업과 실험실</h2><p>예전 GitHub Pages 페이지들은 그대로 두었습니다. 지금 보면 부족한 것도 많지만, 출발점으로 남겨두고 싶었습니다.</p></div>
      <div class="archive-grid">
        {archiveItems.map(([type, year, title, desc, href]) => <a class="archive-card" href={href} target={href.startsWith('/homepage') || href.startsWith('/study') ? '_blank' : undefined} rel="noopener noreferrer"><div class="archive-card-header"><span class={`archive-tag ${type.toLowerCase()}`}>{type}</span><span class="archive-date">{year}</span></div><h3 class="archive-title">{title}</h3><p class="archive-desc">{desc}</p></a>)}
      </div>
    </section>

    <section id="contact" class="section-shell contact" aria-labelledby="contact-title">
      <div><p class="section-kicker">Contact</p><h2 id="contact-title">지금도 뭔가를 만들고 있습니다.</h2><p>작업과 코드는 GitHub에 올려두고 있습니다. 협업, 피드백, 문의는 <a href="mailto:zyqn@naver.com">zyqn@naver.com</a>으로 연락해 주세요.</p></div>
      <a class="button primary" href="mailto:zyqn@naver.com">이메일 보내기</a>
    </section>
  </main>
</BaseLayout>
