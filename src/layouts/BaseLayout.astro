---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  // OG/트위터 카드 이미지(루트 기준 경로). 없으면 /og/default.png 로 대체된다.
  image?: string;
}

const {
  title = 'slowave · AI와 제품 실험을 기록하는 블로그',
  description = '아이디어를 제품으로 옮기는 과정을 기록하는 개인 포트폴리오와 블로그.',
  canonical = Astro.url.pathname,
  ogType = 'website',
  robots = 'index, follow',
  jsonLd,
  publishedTime,
  modifiedTime,
  tags = [],
  image = '/og/default.png',
} = Astro.props;
const site = Astro.site ?? new URL('https://perust.github.io');
const canonicalUrl = new URL(canonical, site).toString();
const ogImageUrl = new URL(image, site).toString();
const siteName = 'slowave';
// JSON-LD를 단일 객체/배열 모두 허용하고, </script> 주입을 막기 위해 < 를 이스케이프한다.
const structuredData = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const serializeJsonLd = (data: Record<string, unknown>) =>
  JSON.stringify(data).replace(/</g, '\\u003c');
const navItems = [
  ['/', '홈'],
  ['/blog/', '블로그'],
  ['/about/', '소개'],
  ['/contact/', '문의'],
];
const isCurrent = (href: string) => href === '/' ? Astro.url.pathname === '/' : Astro.url.pathname.startsWith(href);
---
<!doctype html>
<html lang="ko">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HLB0E46BLH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HLB0E46BLH');
    </script>
    <!-- Microsoft Clarity tracking code -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i+"?ref=bwt";
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xfwvbc1z9a");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="slowave Blog RSS" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {ogType === 'article' && (
      <>
        {publishedTime && <meta property="article:published_time" content={publishedTime} />}
        {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
        {tags.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+KR:wght@400;500;700;800&display=swap" rel="stylesheet" />
    {structuredData.map((data) => (
      <script type="application/ld+json" is:inline set:html={serializeJsonLd(data)} />
    ))}
    <slot name="head" />
  </head>
  <body>
    <header class="site-header" aria-label="사이트 헤더">
      <a class="brand" href="/" aria-label="홈으로 이동">
        <span class="brand-mark">S</span>
        <span>slowave</span>
      </a>
      <nav class="nav" aria-label="주요 메뉴">
        {navItems.map(([href, label]) => <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>)}
      </nav>
    </header>
    <slot />
    <footer class="footer">
      <p>© 2026 slowave. Built with Astro on GitHub Pages.</p>
      <div class="footer-links">
        <a href="/privacy/">개인정보처리방침</a>
        <a href="/contact/">문의</a>
        <a href="/blog/">블로그</a>
      </div>
    </footer>
  </body>
</html>
